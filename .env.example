# Common application settings
# - Docker Compose는 이 파일을 자동으로 읽습니다.
# - 호스트에서 ./gradlew bootRun 으로 실행할 때는 필요한 값만 쉘/IDE 환경변수로 주입합니다.
# - IntelliJ 환경 변수 칸에는 `.env` 파일 경로를 넣지 말고 `KEY=value;KEY2=value2` 형식으로 직접 입력합니다.
SPRING_PROFILES_ACTIVE=local
APP_VERSION=local
APP_HOST_BIND=127.0.0.1
APP_HOST_PORT=8080
SERVER_PORT=8080
JAVA_OPTS="-Xms256m -Xmx512m"
OPENAPI_ENABLED=true
API_ALLOWED_ORIGIN_PATTERNS="http://localhost:*,http://127.0.0.1:*"
CHAT_WS_ALLOWED_ORIGIN_PATTERNS="http://localhost:*,http://127.0.0.1:*"
MEDIA_STORAGE_PROVIDER=LOCAL
MEDIA_STORAGE_BASE_DIR=var/media
MEDIA_STORAGE_PUBLIC_BASE_URL=http://localhost:8080/uploads
MEDIA_STORAGE_FIREBASE_BUCKET=
# Optional production override for CD admin CORS smoke check.
# Leave empty to reuse the first exact origin from API_ALLOWED_ORIGIN_PATTERNS.
CD_SMOKE_CORS_ORIGIN=
JPA_DDL_AUTO=update
JPA_SHOW_SQL=true
JPA_FORMAT_SQL=true
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=INFO

# Optional when running the app directly on the host (`./gradlew bootRun`)
DB_URL="jdbc:mysql://localhost:3306/skuri?serverTimezone=Asia/Seoul&characterEncoding=UTF-8"
DB_USERNAME=root
DB_PASSWORD=1234

# MySQL / Redis values used by local docker-compose and single-host production compose
MYSQL_DATABASE=skuri
MYSQL_USER=skuri
MYSQL_PASSWORD=skuri
MYSQL_ROOT_PASSWORD=skuri-root
# Production MySQL admin access is exposed to loopback only by default.
MYSQL_HOST_BIND=127.0.0.1
MYSQL_HOST_PORT=3307
MYSQL_LOCAL_PORT=3306
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_TIMEOUT=2000ms
REDIS_LOCAL_PORT=6379

# Firebase
FIREBASE_PROJECT_ID=
FIREBASE_CREDENTIALS_PATH=
GOOGLE_APPLICATION_CREDENTIALS=
FIREBASE_CREDENTIALS_FILE=
# local-emulator 실행 시에는 아래 값을 실행 환경에서 명시적으로 덮어쓰세요.
# - FIREBASE_AUTH_USE_EMULATOR=true
# - FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
# - FIREBASE_CREDENTIALS_PATH=
# - GOOGLE_APPLICATION_CREDENTIALS=
FIREBASE_AUTH_EMULATOR_HOST=

# OCI single-host production tip
# - `docker-compose.prod.yml` wires the app container to the internal `mysql`/`redis` services.
# - 운영 app 포트는 `${APP_HOST_BIND:-127.0.0.1}:${APP_HOST_PORT:-8080}` loopback 바인딩을 유지해 Nginx만 접근하게 한다.
# - If you need MySQL Workbench access, keep MySQL published only to `${MYSQL_HOST_BIND:-127.0.0.1}:${MYSQL_HOST_PORT:-3307}`
#   and connect through SSH tunneling instead of opening `3306` to the internet.
# - For production compose, keep `SPRING_PROFILES_ACTIVE=prod` and fill MYSQL_*, APP_HOST_BIND, APP_HOST_PORT,
#   FIREBASE_CREDENTIALS_FILE, GOOGLE_APPLICATION_CREDENTIALS, MEDIA_STORAGE_PUBLIC_BASE_URL,
#   MEDIA_STORAGE_PROVIDER, MEDIA_STORAGE_FIREBASE_BUCKET.

# Optional future external AI service
AI_SERVICE_BASE_URL=
AI_SERVICE_AUTH_TOKEN=
AI_SERVICE_TIMEOUT_MS=5000
