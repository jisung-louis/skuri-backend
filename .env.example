# Common application settings
# - Docker Compose는 이 파일을 자동으로 읽습니다.
# - 호스트에서 ./gradlew bootRun 으로 실행할 때는 `.env` 값을 쉘/IDE 환경변수로 먼저 로드해야 합니다.
SPRING_PROFILES_ACTIVE=local
APP_VERSION=local
APP_HOST_PORT=8080
SERVER_PORT=8080
JAVA_OPTS="-Xms256m -Xmx512m"
OPENAPI_ENABLED=true
CHAT_WS_ALLOWED_ORIGIN_PATTERNS="http://localhost:*,http://127.0.0.1:*"
JPA_DDL_AUTO=update
JPA_SHOW_SQL=true
JPA_FORMAT_SQL=true
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=INFO

# Optional when running the app directly on the host (`./gradlew bootRun`)
DB_URL="jdbc:mysql://localhost:3306/skuri?serverTimezone=Asia/Seoul&characterEncoding=UTF-8"
DB_USERNAME=root
DB_PASSWORD=1234

# MySQL / Redis values used by local docker-compose and single-host production compose
MYSQL_DATABASE=skuri
MYSQL_USER=skuri
MYSQL_PASSWORD=skuri
MYSQL_ROOT_PASSWORD=skuri-root
MYSQL_LOCAL_PORT=3306
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_TIMEOUT=2000ms
REDIS_LOCAL_PORT=6379

# Firebase
FIREBASE_PROJECT_ID=
FIREBASE_CREDENTIALS_PATH=
GOOGLE_APPLICATION_CREDENTIALS=
FIREBASE_CREDENTIALS_FILE=
FIREBASE_AUTH_USE_EMULATOR=false
FIREBASE_AUTH_EMULATOR_HOST=

# OCI single-host production tip
# - `docker-compose.prod.yml` wires the app container to the internal `mysql`/`redis` services.
# - For production compose, keep `SPRING_PROFILES_ACTIVE=prod` and fill MYSQL_*, APP_HOST_PORT,
#   FIREBASE_CREDENTIALS_FILE, GOOGLE_APPLICATION_CREDENTIALS only.

# Optional future external AI service
AI_SERVICE_BASE_URL=
AI_SERVICE_AUTH_TOKEN=
AI_SERVICE_TIMEOUT_MS=5000
